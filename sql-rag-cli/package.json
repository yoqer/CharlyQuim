{
  "name": "sql-rag-cli",
  "version": "2.0.0",
  "description": "Enhanced CLI tool using Void's RAG system to find and fix SQL code with DBT/Snowflake integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "sql-rag": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "@vscode/ripgrep": "^1.15.11",
    "glob": "^10.3.10",
    "fs-extra": "^11.2.0",
    "snowflake-sdk": "^1.9.3",
    "dotenv": "^16.3.1",
    "node-sql-parser": "^4.17.0",
    "sql-formatter": "^15.3.2",
    "openai": "^4.47.1",
    "yaml": "^2.3.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.4.5",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2"
  },
  "keywords": ["sql", "rag", "dbt", "snowflake", "code-search", "ai"],
  "author": "SQL RAG Team",
  "license": "MIT"
}
